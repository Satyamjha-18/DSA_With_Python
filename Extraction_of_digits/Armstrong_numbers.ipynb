     "text": [
      "Number is Armstrong\n"
     ]
    }
   ],
   "source": [
    "n = 153\n",
    "\n",
    "num = n\n",
    "total = 0\n",
    "no_of_digit = len(str(n))\n",
    "\n",
    "while num > 0:\n",
    "    last_digit = num % 10\n",
    "    total = total + (last_digit ** no_of_digit)\n",
    "    num //= 10\n",
    "\n",
    "if total == n:\n",
    "    print(\"Number is Armstrong\")\n",
    "else:\n",
    "    print(\"Number is not Armstrong\")"
   ]
  },
